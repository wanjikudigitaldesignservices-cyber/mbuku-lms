# mbuku LMS — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Supabase (client-safe keys only)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# IMPORTANT: The following keys must NEVER be in client-side code
# They should only be set as Supabase Edge Function secrets:
# - SUPABASE_SERVICE_ROLE_KEY
# - ANTHROPIC_API_KEY
# - INTASEND_SECRET_KEY (if Phase 8 is implemented)
